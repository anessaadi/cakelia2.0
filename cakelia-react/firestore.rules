rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profile ──────────────────────────────────────────────────────
    // Only the authenticated owner can read or write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // ── Friends subcollection ──────────────────────────────────────────
      // Same owner-only constraint.
      match /friends/{friendId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Mail log ──────────────────────────────────────────────────────────
    // Written exclusively by Cloud Functions via the Admin SDK.
    // No client — authenticated or not — may read or write this collection.
    match /mail_log/{logId} {
      allow read, write: if false;
    }

    // ── Contact messages ──────────────────────────────────────────────────
    // Anyone may create a message (the contact form); no one may read,
    // update, or delete via the client (owner reads in Firebase console).
    // Implemented fully in Phase 5 — placeholder rule added now so the
    // collection is protected from the start.
    match /contact_messages/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
